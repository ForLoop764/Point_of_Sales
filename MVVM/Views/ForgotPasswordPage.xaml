<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Point_of_Sales.MVVM.Views.ForgotPasswordPage"
             BackgroundColor="{StaticResource Background}">

    <Grid>

        <ScrollView VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Padding="32,56,32,40" Spacing="0" VerticalOptions="Center">

                <!-- Logo + Brand Block -->
                <VerticalStackLayout Spacing="4" Margin="0,0,0,36" HorizontalOptions="Start">
                    <Image Source="shoepair_logo.png"
                           HeightRequest="72"
                           WidthRequest="72"
                           HorizontalOptions="Start"
                           Aspect="AspectFit"
                           Margin="0,0,0,14" />

                    <Label FontSize="34" FontAttributes="Bold"
                           TextColor="{StaticResource TextMain}" HorizontalOptions="Start">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="Forgot " TextColor="{StaticResource TextMain}"
                                      FontSize="34" FontAttributes="Bold"/>
                                <Span Text="Password" TextColor="{StaticResource Primary}"
                                      FontSize="34" FontAttributes="Bold"/>
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                    <Label Text="We'll send a reset link to your email"
                           FontSize="13" TextColor="{StaticResource TextSub}"
                           HorizontalOptions="Start" Margin="0,4,0,0" />
                </VerticalStackLayout>
                
                <!-- Email Step Card -->
                <Border x:Name="EmailCard"
                        BackgroundColor="{StaticResource CardDark}"
                        StrokeShape="RoundRectangle 8"
                        Stroke="{StaticResource BorderGray}" StrokeThickness="1.5"
                        Padding="24,28" Margin="0,0,0,20">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.5" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="20">

                        <!-- Email field -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="EMAIL ADDRESS" FontSize="11"
                                   CharacterSpacing="2" TextColor="{StaticResource TextMain}" />
                            <Border x:Name="EmailBorder"
                                    BackgroundColor="{StaticResource CardLight}"
                                    StrokeShape="RoundRectangle 4"
                                    Stroke="Transparent"
                                    StrokeThickness="1.5"
                                    Padding="16,0">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                    <Label Grid.Column="0" Text="✉️" FontSize="16"
                                           VerticalOptions="Center" TextColor="{StaticResource TextSub}" />
                                    <Entry Grid.Column="1"
                                           x:Name="EmailEntry"
                                           Placeholder="Enter your email"
                                           PlaceholderColor="{StaticResource TextSub}"
                                           TextColor="White"
                                           Keyboard="Email"
                                           BackgroundColor="Transparent"
                                           HeightRequest="52"
                                           FontSize="15"
                                           ReturnType="Send"
                                           Completed="OnSendClicked" />
                                </Grid>
                            </Border>
                            <Label x:Name="EmailErrorLabel"
                                   TextColor="{StaticResource Red}"
                                   FontSize="12"
                                   Margin="4,0,0,0"
                                   IsVisible="False" />
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>
                
                <!-- Send Button -->
                <Button x:Name="SendButton"
                        Text="SEND RESET LINK"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White"
                        FontAttributes="Bold"
                        FontSize="15"
                        CharacterSpacing="1"
                        CornerRadius="4"
                        HeightRequest="56"
                        Margin="0,0,0,12"
                        Clicked="OnSendClicked">
                </Button>

                <!-- Loading Indicator -->
                <ActivityIndicator x:Name="LoadingIndicator"
                                   IsRunning="False"
                                   IsVisible="False"
                                   Color="{StaticResource Primary}"
                                   Margin="0,4,0,12" />

                <!-- Success Step Card -->
                <Border x:Name="SuccessCard"
                        BackgroundColor="{StaticResource CardDark}"
                        StrokeShape="RoundRectangle 8"
                        Stroke="{StaticResource BorderGray}" StrokeThickness="1.5"
                        Padding="24,28" Margin="0,0,0,20"
                        IsVisible="False">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.5" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="20">

                        <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                            <Label Text="✅" FontSize="48" HorizontalOptions="Center" />
                            <Label Text="Reset Link Sent!"
                                   FontSize="20" FontAttributes="Bold"
                                   TextColor="{StaticResource TextMain}"
                                   HorizontalOptions="Center" />
                            <Label x:Name="ConfirmationLabel"
                                   FontSize="13" TextColor="{StaticResource TextSub}"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" Color="{StaticResource BorderGray}" />

                        <Label Text="Didn't receive it? Check your spam folder."
                               FontSize="12" TextColor="{StaticResource TextSub}"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center" />

                        <!-- Try Again -->

                        <Button Text="TRY AGAIN"
                                BackgroundColor="Transparent"
                                TextColor="{StaticResource Primary}"
                                FontAttributes="Bold"
                                FontSize="14"
                                CharacterSpacing="1"
                                BorderColor="{StaticResource Primary}"
                                BorderWidth="1.5"
                                CornerRadius="4"
                                HeightRequest="50"
                                Clicked="OnTryAgainClicked" />

                    </VerticalStackLayout>
                </Border>

                <!-- Divider -->
                <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="12"
                      Margin="0,8,0,20" VerticalOptions="Center">
                    <BoxView Grid.Column="0" HeightRequest="1"
                             Color="{StaticResource BorderGray}" VerticalOptions="Center" />
                    <Label Grid.Column="1" Text="OR" FontSize="11"
                           CharacterSpacing="2" TextColor="{StaticResource TextSub}"
                           VerticalOptions="Center" />
                    <BoxView Grid.Column="2" HeightRequest="1"
                             Color="{StaticResource BorderGray}" VerticalOptions="Center" />
                </Grid>

                <!-- SIGN IN -->
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="6">
                    <Label Text="Remember your account?"
                           FontSize="13" TextColor="{StaticResource TextSub}"
                           VerticalOptions="Center" />
                    <Button Text="SIGN IN"
                             FontSize="13"
                             FontAttributes="Bold"
                             TextColor="{StaticResource Primary}"
                             CharacterSpacing="1"
                             BackgroundColor="Transparent"
                             Clicked="OnSignInClicked" />
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>