<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Point_of_Sales.MVVM.Views.ForgotPasswordPage"
             BackgroundColor="#F7F8FA">

    <Grid>

        <!-- ── Decorative Blobs (same as LoginPage) ── -->
        <AbsoluteLayout InputTransparent="True">
            <BoxView AbsoluteLayout.LayoutBounds="1.08, -0.03, 230, 230"
                     AbsoluteLayout.LayoutFlags="PositionProportional"
                     Color="#EDE7F6" CornerRadius="115" />
            <BoxView AbsoluteLayout.LayoutBounds="0.90, 0.08, 110, 110"
                     AbsoluteLayout.LayoutFlags="PositionProportional"
                     Color="#D1C4E9" CornerRadius="55" />
            <BoxView AbsoluteLayout.LayoutBounds="-0.06, 1.04, 190, 190"
                     AbsoluteLayout.LayoutFlags="PositionProportional"
                     Color="#FFF3E0" CornerRadius="95" />
            <BoxView AbsoluteLayout.LayoutBounds="-0.06, 0.88, 90, 90"
                     AbsoluteLayout.LayoutFlags="PositionProportional"
                     Color="#FFE0B2" CornerRadius="45" />
            <BoxView AbsoluteLayout.LayoutBounds="0.0, 0.42, 70, 3"
                     AbsoluteLayout.LayoutFlags="PositionProportional"
                     Color="#7B2FBE" />
        </AbsoluteLayout>

        <ScrollView VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Padding="32,56,32,40" Spacing="0" VerticalOptions="Center">

                <!-- ── Logo + Brand Block ── -->
                <VerticalStackLayout Spacing="4" Margin="0,0,0,36" HorizontalOptions="Start">
                    <Image Source="shoepair_logo.png"
                           HeightRequest="72"
                           WidthRequest="72"
                           HorizontalOptions="Start"
                           Aspect="AspectFit"
                           Margin="0,0,0,14" />

                    <Label FontSize="34" FontAttributes="Bold"
                           TextColor="#1A1A1A" HorizontalOptions="Start">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="Forgot " TextColor="#1A1A1A"
                                      FontSize="34" FontAttributes="Bold"/>
                                <Span Text="Password" TextColor="#FF8C00"
                                      FontSize="34" FontAttributes="Bold"/>
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                    <Label Text="We'll send a reset link to your email"
                           FontSize="13" TextColor="#9E9E9E"
                           HorizontalOptions="Start" Margin="0,4,0,0" />
                </VerticalStackLayout>

                <!-- ── Email Step Card ── -->
                <Border x:Name="EmailCard"
                        BackgroundColor="White"
                        StrokeShape="RoundRectangle 20"
                        Stroke="#EBEBEB" StrokeThickness="1.5"
                        Padding="24,28" Margin="0,0,0,20">
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,4" Radius="20" Opacity="0.07" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="20">

                        <!-- Email field -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="EMAIL ADDRESS" FontSize="Caption"
                                   CharacterSpacing="2" TextColor="Black" />
                            <Border x:Name="EmailBorder"
                                    BackgroundColor="#F7F8FA"
                                    StrokeShape="RoundRectangle 12"
                                    Stroke="#E0E0E0"
                                    StrokeThickness="1.5"
                                    Padding="16,0">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                    <Label Grid.Column="0" Text="✉️" FontSize="16"
                                           VerticalOptions="Center" TextColor="#BDBDBD" />
                                    <Entry Grid.Column="1"
                                           x:Name="EmailEntry"
                                           Placeholder="Enter your email"
                                           PlaceholderColor="#BDBDBD"
                                           TextColor="#1A1A1A"
                                           Keyboard="Email"
                                           BackgroundColor="Transparent"
                                           HeightRequest="52"
                                           FontSize="15"
                                           ReturnType="Send"
                                           Completed="OnSendClicked" />
                                </Grid>
                            </Border>
                            <!-- Inline error -->
                            <Label x:Name="EmailErrorLabel"
                                   TextColor="#E53935"
                                   FontSize="12"
                                   Margin="4,0,0,0"
                                   IsVisible="False" />
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

                <!-- ── Send Button ── -->
                <Button x:Name="SendButton"
                        Text="SEND RESET LINK"
                        BackgroundColor="#408A71"
                        TextColor="White"
                        FontAttributes="Bold"
                        FontSize="15"
                        CharacterSpacing="1"
                        CornerRadius="14"
                        HeightRequest="56"
                        Margin="0,0,0,12"
                        Clicked="OnSendClicked">
                    <Button.Shadow>
                        <Shadow Brush="#7B2FBE" Offset="0,6" Radius="16" Opacity="0.30" />
                    </Button.Shadow>
                </Button>

                <!-- ── Loading Indicator ── -->
                <ActivityIndicator x:Name="LoadingIndicator"
                                   IsRunning="False"
                                   IsVisible="False"
                                   Color="#7B2FBE"
                                   Margin="0,4,0,12" />

                <!-- ── Success Step Card ── -->
                <Border x:Name="SuccessCard"
                        BackgroundColor="White"
                        StrokeShape="RoundRectangle 20"
                        Stroke="#EBEBEB" StrokeThickness="1.5"
                        Padding="24,28" Margin="0,0,0,20"
                        IsVisible="False">
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,4" Radius="20" Opacity="0.07" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="20">

                        <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                            <Label Text="✅" FontSize="48" HorizontalOptions="Center" />
                            <Label Text="Reset Link Sent!"
                                   FontSize="20" FontAttributes="Bold"
                                   TextColor="#1A1A1A"
                                   HorizontalOptions="Center" />
                            <Label x:Name="ConfirmationLabel"
                                   FontSize="13" TextColor="#9E9E9E"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" Color="#E0E0E0" />

                        <Label Text="Didn't receive it? Check your spam folder."
                               FontSize="12" TextColor="#BDBDBD"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center" />

                        <!-- Try Again -->
                        <Button Text="TRY AGAIN"
                                BackgroundColor="Transparent"
                                TextColor="#FF8C00"
                                FontAttributes="Bold"
                                FontSize="14"
                                CharacterSpacing="1"
                                BorderColor="#FF8C00"
                                BorderWidth="1.5"
                                CornerRadius="14"
                                HeightRequest="50"
                                Clicked="OnTryAgainClicked" />

                    </VerticalStackLayout>
                </Border>

                <!-- ── Divider ── -->
                <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="12"
                      Margin="0,8,0,20" VerticalOptions="Center">
                    <BoxView Grid.Column="0" HeightRequest="1"
                             Color="#E0E0E0" VerticalOptions="Center" />
                    <Label Grid.Column="1" Text="OR" FontSize="11"
                           CharacterSpacing="2" TextColor="#BDBDBD"
                           VerticalOptions="Center" />
                    <BoxView Grid.Column="2" HeightRequest="1"
                             Color="#E0E0E0" VerticalOptions="Center" />
                </Grid>

                <!-- ── Back to Login ── -->
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="6">
                    <Label Text="Remember your password?"
                           FontSize="13" TextColor="#9E9E9E"
                           VerticalOptions="Center" />
                    <Button Text="SIGN IN"
                            FontSize="13"
                            FontAttributes="Bold"
                            TextColor="#FF8C00"
                            CharacterSpacing="1"
                            BackgroundColor="Transparent"
                            Clicked="OnSignInClicked" />
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
