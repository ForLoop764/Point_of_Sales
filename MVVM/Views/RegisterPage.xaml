<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Point_of_Sales.MVVM.Views.RegisterPage"
             BackgroundColor="#F7F8FA">

    <Grid>

        <ScrollView VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Padding="32,52,32,40" Spacing="0" VerticalOptions="Start">

                <!-- Logo + Brand -->
                <VerticalStackLayout Spacing="4" Margin="0,0,0,28" HorizontalOptions="Start">
                    <Image Source="logo.png"
                           HeightRequest="64" WidthRequest="64"
                           HorizontalOptions="Start"
                           Aspect="AspectFit"
                           Margin="0,0,0,14" />
                    <Label FontSize="34" FontAttributes="Bold" HorizontalOptions="Start">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="Create " TextColor="#1A1A1A"
                                      FontSize="34" FontAttributes="Bold"/>
                                <Span Text="Account" TextColor="#FF8C00"
                                      FontSize="34" FontAttributes="Bold"/>
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                    <Label Text="Set up your new POS account"
                           FontSize="13" TextColor="#9E9E9E"
                           HorizontalOptions="Start" Margin="0,4,0,0" />
                </VerticalStackLayout>

                <!-- Input Card -->
                <Border BackgroundColor="White"
                        StrokeShape="RoundRectangle 20"
                        Stroke="#EBEBEB" StrokeThickness="1.5"
                        Padding="24,28" Margin="0,0,0,16">
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,4" Radius="20" Opacity="0.07" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="20">

                        <!-- Username -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="USERNAME" FontSize="Caption"
                                   CharacterSpacing="2" TextColor="Black" />
                            <Border BackgroundColor="#F7F8FA"
                                    StrokeShape="RoundRectangle 12"
                                    Stroke="#E0E0E0" StrokeThickness="1.5" Padding="16,0">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                    <Label Grid.Column="0" Text="👤" FontSize="16"
                                           VerticalOptions="Center" TextColor="#BDBDBD" />
                                    <Entry Grid.Column="1"
                                           x:Name="UsernameEntry"
                                           Text="{Binding Username}"
                                           Placeholder="Choose a username"
                                           PlaceholderColor="#BDBDBD"
                                           TextColor="#1A1A1A"
                                           BackgroundColor="Transparent"
                                           HeightRequest="52" FontSize="15" />
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Email -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="EMAIL ADDRESS" FontSize="Caption"
                                   CharacterSpacing="2" TextColor="Black" />
                            <Border BackgroundColor="#F7F8FA"
                                    StrokeShape="RoundRectangle 12"
                                    Stroke="#E0E0E0" StrokeThickness="1.5" Padding="16,0">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                    <Label Grid.Column="0" Text="✉️" FontSize="16"
                                           VerticalOptions="Center" TextColor="#BDBDBD" />
                                    <Entry Grid.Column="1"
                                           x:Name="EmailEntry"
                                           Text="{Binding Email}"
                                           Placeholder="Enter your email"
                                           PlaceholderColor="#BDBDBD"
                                           Keyboard="Email"
                                           TextColor="#1A1A1A"
                                           BackgroundColor="Transparent"
                                           HeightRequest="52" FontSize="15" />
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Password -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="PASSWORD" FontSize="Caption"
                                   CharacterSpacing="2" TextColor="Black" />
                            <Border BackgroundColor="#F7F8FA"
                                    StrokeShape="RoundRectangle 12"
                                    Stroke="#E0E0E0" StrokeThickness="1.5" Padding="16,0">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                    <Label Grid.Column="0" Text="🔒" FontSize="16"
                                           VerticalOptions="Center" TextColor="#BDBDBD" />
                                    <Entry Grid.Column="1"
                                           x:Name="PasswordEntry"
                                           Text="{Binding Password}"
                                           Placeholder="Create a password"
                                           PlaceholderColor="#BDBDBD"
                                           IsPassword="{Binding IsPasswordHidden}"
                                           TextColor="#1A1A1A"
                                           BackgroundColor="Transparent"
                                           HeightRequest="52" FontSize="15" />
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Confirm Password -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="CONFIRM PASSWORD" FontSize="Caption"
                                   CharacterSpacing="2" TextColor="Black" />
                            <Border BackgroundColor="#F7F8FA"
                                    StrokeShape="RoundRectangle 12"
                                    Stroke="#E0E0E0" StrokeThickness="1.5" Padding="16,0">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                    <Label Grid.Column="0" Text="🔐" FontSize="16"
                                           VerticalOptions="Center" TextColor="#BDBDBD" />
                                    <Entry Grid.Column="1"
                                           x:Name="ConfirmPasswordEntry"
                                           Text="{Binding ConfirmPassword}"
                                           Placeholder="Re-enter your password"
                                           PlaceholderColor="#BDBDBD"
                                           IsPassword="{Binding IsPasswordHidden}"
                                           TextColor="#1A1A1A"
                                           BackgroundColor="Transparent"
                                           HeightRequest="52" FontSize="15" />
                                </Grid>
                            </Border>

                            <!-- Show Password Checkbox -->
                            <HorizontalStackLayout Spacing="8" Margin="4,4,0,0">
                                <CheckBox Color="#408A71"
                                          CheckedChanged="OnShowPasswordCheckedChanged" />
                                <Label Text="Show Password"
                                       FontSize="13" TextColor="#9E9E9E"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>

                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

                <!-- Register Button -->
                <Button Text="CREATE ACCOUNT"
                        Command="{Binding RegisterCommand}"
                        BackgroundColor="#408A71"
                        TextColor="White"
                        FontAttributes="Bold"
                        FontSize="15"
                        CharacterSpacing="1"
                        CornerRadius="14"
                        HeightRequest="56"
                        Margin="0,0,0,12">
                    <Button.Shadow>
                        <Shadow Brush="#7B2FBE" Offset="0,6" Radius="16" Opacity="0.30" />
                    </Button.Shadow>
                </Button>

                <!-- Divider -->
                <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="12"
                      Margin="0,20,0,20" VerticalOptions="Center">
                    <BoxView Grid.Column="0" HeightRequest="1"
                             Color="#E0E0E0" VerticalOptions="Center" />
                    <Label Grid.Column="1" Text="OR" FontSize="11"
                           CharacterSpacing="2" TextColor="#BDBDBD"
                           VerticalOptions="Center" />
                    <BoxView Grid.Column="2" HeightRequest="1"
                             Color="#E0E0E0" VerticalOptions="Center" />
                </Grid>

                <!-- Sign In -->
                <HorizontalStackLayout HorizontalOptions="Center"
                       Spacing="6" Margin="0,0,0,20">
                    <Label Text="Already have an account?"
                           FontSize="13" TextColor="#9E9E9E"
                           VerticalOptions="Center" />
                    
                    <Button Text="SIGN IN"
                            Command="{Binding GoToLoginCommand}"
                            FontSize="13"
                            FontAttributes="Bold"
                            TextColor="#FF8C00"
                            CharacterSpacing="1"
                            BackgroundColor="Transparent"/>
                    
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>