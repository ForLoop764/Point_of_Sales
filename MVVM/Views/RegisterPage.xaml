<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Point_of_Sales.MVVM.ViewModels"
             x:Class="Point_of_Sales.MVVM.Views.RegisterPage"
             BackgroundColor="#F7F8FA">

    <Grid>

        <AbsoluteLayout InputTransparent="True">
            <!-- Top-left violet bubble -->
            <BoxView AbsoluteLayout.LayoutBounds="-0.06, -0.02, 200, 200"
                     AbsoluteLayout.LayoutFlags="PositionProportional"
                     Color="#EDE7F6" CornerRadius="100" />
            <BoxView AbsoluteLayout.LayoutBounds="0.10, 0.06, 90, 90"
                     AbsoluteLayout.LayoutFlags="PositionProportional"
                     Color="#D1C4E9" CornerRadius="45" />
            <!-- Bottom-right orange bubble -->
            <BoxView AbsoluteLayout.LayoutBounds="1.06, 0.97, 170, 170"
                     AbsoluteLayout.LayoutFlags="PositionProportional"
                     Color="#FFF3E0" CornerRadius="85" />
            <BoxView AbsoluteLayout.LayoutBounds="1.06, 0.84, 80, 80"
                     AbsoluteLayout.LayoutFlags="PositionProportional"
                     Color="#FFE0B2" CornerRadius="40" />
            <!-- Orange accent line -->
            <BoxView AbsoluteLayout.LayoutBounds="1.0, 0.55, 3, 50"
                     AbsoluteLayout.LayoutFlags="PositionProportional"
                     Color="#FF8C00" />
        </AbsoluteLayout>

        <ScrollView VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Padding="32,52,32,40" Spacing="0" VerticalOptions="Start">

                <!-- ── Back Button ── -->
                <HorizontalStackLayout Spacing="6" Margin="0,0,0,24">
                    <Label Text="←" FontSize="18" TextColor="#7B2FBE" VerticalOptions="Center" />
                    <Label Text="Back to Login" FontSize="13" FontAttributes="Bold"
                           TextColor="#7B2FBE" VerticalOptions="Center" />
                </HorizontalStackLayout>

                <!-- ── Logo + Brand Block ── -->
                <VerticalStackLayout Spacing="4" Margin="0,0,0,28" HorizontalOptions="Start">
                    <Image Source="shoepair_logo.png"
                           HeightRequest="64"
                           WidthRequest="64"
                           HorizontalOptions="Start"
                           Aspect="AspectFit"
                           Margin="0,0,0,14" />
                    <Label Text="JOIN US TODAY" FontSize="11" FontAttributes="Bold"
                           CharacterSpacing="4" TextColor="#7B2FBE" HorizontalOptions="Start" />
                    <Label FontSize="34" FontAttributes="Bold" HorizontalOptions="Start">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="Create " TextColor="#1A1A1A" FontSize="34" FontAttributes="Bold"/>
                                <Span Text="Account" TextColor="#FF8C00" FontSize="34" FontAttributes="Bold"/>
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                    <Label Text="Set up your new POS account"
                           FontSize="13" TextColor="#9E9E9E"
                           HorizontalOptions="Start" Margin="0,4,0,0" />
                </VerticalStackLayout>

                <!-- ── Input Card ── -->
                <Border BackgroundColor="White"
                        StrokeShape="RoundRectangle 20"
                        Stroke="#EBEBEB" StrokeThickness="1.5"
                        Padding="24,28" Margin="0,0,0,16">
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,4" Radius="20" Opacity="0.07" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="20">

                        <!-- Full Name -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="FULL NAME" FontSize="10" FontAttributes="Bold"
                                   CharacterSpacing="2" TextColor="#7B2FBE" />
                            <Border BackgroundColor="#F7F8FA"
                                    StrokeShape="RoundRectangle 12"
                                    Stroke="#E0E0E0" StrokeThickness="1.5" Padding="16,0">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                    <Label Grid.Column="0" Text="🪪" FontSize="16"
                                           VerticalOptions="Center" TextColor="#BDBDBD" />
                                    <Entry Grid.Column="1"
                                           Placeholder="Enter your full name"
                                           PlaceholderColor="#BDBDBD"
                                           Text="{Binding FullName}"
                                           TextColor="#1A1A1A"
                                           BackgroundColor="Transparent"
                                           HeightRequest="52" FontSize="15" />
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Username -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="USERNAME" FontSize="10" FontAttributes="Bold"
                                   CharacterSpacing="2" TextColor="#7B2FBE" />
                            <Border BackgroundColor="#F7F8FA"
                                    StrokeShape="RoundRectangle 12"
                                    Stroke="#E0E0E0" StrokeThickness="1.5" Padding="16,0">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                    <Label Grid.Column="0" Text="👤" FontSize="16"
                                           VerticalOptions="Center" TextColor="#BDBDBD" />
                                    <Entry Grid.Column="1"
                                           Placeholder="Choose a username"
                                           PlaceholderColor="#BDBDBD"
                                           Text="{Binding Username}"
                                           TextColor="#1A1A1A"
                                           BackgroundColor="Transparent"
                                           HeightRequest="52" FontSize="15" />
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Email -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="EMAIL ADDRESS" FontSize="10" FontAttributes="Bold"
                                   CharacterSpacing="2" TextColor="#7B2FBE" />
                            <Border BackgroundColor="#F7F8FA"
                                    StrokeShape="RoundRectangle 12"
                                    Stroke="#E0E0E0" StrokeThickness="1.5" Padding="16,0">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                    <Label Grid.Column="0" Text="✉️" FontSize="16"
                                           VerticalOptions="Center" TextColor="#BDBDBD" />
                                    <Entry Grid.Column="1"
                                           Placeholder="Enter your email"
                                           PlaceholderColor="#BDBDBD"
                                           Text="{Binding Email}"
                                           Keyboard="Email"
                                           TextColor="#1A1A1A"
                                           BackgroundColor="Transparent"
                                           HeightRequest="52" FontSize="15" />
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Password -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="PASSWORD" FontSize="10" FontAttributes="Bold"
                                   CharacterSpacing="2" TextColor="#7B2FBE" />
                            <Border BackgroundColor="#F7F8FA"
                                    StrokeShape="RoundRectangle 12"
                                    Stroke="#E0E0E0" StrokeThickness="1.5" Padding="16,0">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                    <Label Grid.Column="0" Text="🔒" FontSize="16"
                                           VerticalOptions="Center" TextColor="#BDBDBD" />
                                    <Entry Grid.Column="1"
                                           Placeholder="Create a password"
                                           PlaceholderColor="#BDBDBD"
                                           Text="{Binding Password}"
                                           IsPassword="True"
                                           TextColor="#1A1A1A"
                                           BackgroundColor="Transparent"
                                           HeightRequest="52" FontSize="15" />
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Confirm Password -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="CONFIRM PASSWORD" FontSize="10" FontAttributes="Bold"
                                   CharacterSpacing="2" TextColor="#7B2FBE" />
                            <Border BackgroundColor="#F7F8FA"
                                    StrokeShape="RoundRectangle 12"
                                    Stroke="#E0E0E0" StrokeThickness="1.5" Padding="16,0">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                    <Label Grid.Column="0" Text="🔐" FontSize="16"
                                           VerticalOptions="Center" TextColor="#BDBDBD" />
                                    <Entry Grid.Column="1"
                                           Placeholder="Re-enter your password"
                                           PlaceholderColor="#BDBDBD"
                                           Text="{Binding ConfirmPassword}"
                                           IsPassword="True"
                                           TextColor="#1A1A1A"
                                           BackgroundColor="Transparent"
                                           HeightRequest="52" FontSize="15" />
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

                <!-- ── Register Button ── -->
                <Button Text="CREATE ACCOUNT  →"
                        Command="{Binding RegisterCommand}"
                        BackgroundColor="#7B2FBE"
                        TextColor="White"
                        FontAttributes="Bold"
                        FontSize="15"
                        CharacterSpacing="1"
                        CornerRadius="14"
                        HeightRequest="56"
                        Margin="0,0,0,12">
                    <Button.Shadow>
                        <Shadow Brush="#7B2FBE" Offset="0,6" Radius="16" Opacity="0.30" />
                    </Button.Shadow>
                </Button>

                <!-- ── Loading ── -->
                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Color="#7B2FBE" Margin="0,4,0,0" />

                <!-- ── Divider ── -->
                <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="12"
                      Margin="0,20,0,20" VerticalOptions="Center">
                    <BoxView Grid.Column="0" HeightRequest="1" Color="#E0E0E0" VerticalOptions="Center" />
                    <Label Grid.Column="1" Text="OR" FontSize="11"
                           CharacterSpacing="2" TextColor="#BDBDBD" VerticalOptions="Center" />
                    <BoxView Grid.Column="2" HeightRequest="1" Color="#E0E0E0" VerticalOptions="Center" />
                </Grid>

                <!-- ── Sign In ── -->
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="6">
                    <Label Text="Already have an account?"
                           FontSize="13" TextColor="#9E9E9E" VerticalOptions="Center" />
                    <Button Text="SIGN IN" FontSize="13" FontAttributes="Bold"
                           TextColor="#FF8C00" VerticalOptions="Center" CharacterSpacing="1" 
                            BackgroundColor="Transparent"
                            Clicked="Button_Clicked"/>
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
