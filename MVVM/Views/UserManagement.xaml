<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Point_of_Sales.MVVM.Views.UserManagement"
             BackgroundColor="#141414"
             Shell.NavBarIsVisible="False">

	<Grid RowDefinitions="Auto,*">

		<!-- HEADER -->
		<Grid Grid.Row="0" Padding="20,50,20,10">
			<Label Text="USERS"
                   TextColor="White"
                   FontSize="20"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"/>
		</Grid>

		<!-- CONTENT -->
		<Grid Grid.Row="1">

			<ScrollView>
				<VerticalStackLayout Padding="20" Spacing="10">

					<!-- USER LIST -->
					<CollectionView ItemsSource="{Binding Users}">
						<CollectionView.ItemTemplate>
							<DataTemplate>
								<Frame BackgroundColor="#1F1F1F"
                                       CornerRadius="8"
                                       Padding="12"
                                       Margin="0,4"
                                       HasShadow="False">

									<Grid ColumnDefinitions="Auto,*,Auto">

										<!-- Avatar -->
										<Frame WidthRequest="40"
                                               HeightRequest="40"
                                               CornerRadius="20"
                                               BackgroundColor="{StaticResource Primary}"
                                               Padding="0">
											<Label Text="{Binding Initials}"
                                                   TextColor="White"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"
                                                   FontAttributes="Bold"/>
										</Frame>

										<!-- Info -->
										<VerticalStackLayout Grid.Column="1" Margin="10,0">
											<Label Text="{Binding Name}"
                                                   TextColor="White"
                                                   FontAttributes="Bold"/>
											<Label Text="{Binding Role}"
                                                   TextColor="#808080"
                                                   FontSize="12"/>
										</VerticalStackLayout>

										<!-- Actions -->
										<VerticalStackLayout Grid.Column="2">

											<Label Text="{Binding Status}"
                                                   TextColor="{Binding Color}"
                                                   FontSize="11"
                                                   FontAttributes="Bold"
                                                   HorizontalOptions="End"/>

											<HorizontalStackLayout>
												<Button Text="✏️"
                                                        BackgroundColor="Transparent"
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditUserCommand}"
                                                        CommandParameter="{Binding}"/>

												<Button Text="🗑️"
                                                        BackgroundColor="Transparent"
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteUserCommand}"
                                                        CommandParameter="{Binding}"/>
											</HorizontalStackLayout>

										</VerticalStackLayout>

									</Grid>
								</Frame>
							</DataTemplate>
						</CollectionView.ItemTemplate>
					</CollectionView>

				</VerticalStackLayout>
			</ScrollView>

			<!-- FLOATING ADD BUTTON -->
			<Button Text="+"
                    FontSize="24"
                    TextColor="White"
                    BackgroundColor="{StaticResource Primary}"
                    WidthRequest="60"
                    HeightRequest="60"
                    CornerRadius="30"
                    HorizontalOptions="End"
                    VerticalOptions="End"
                    Margin="20"
                    Command="{Binding AddUserCommand}"/>

		</Grid>

	</Grid>
</ContentPage>