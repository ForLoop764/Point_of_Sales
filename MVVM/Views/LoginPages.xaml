<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Point_of_Sales.MVVM.ViewModels"
             x:Class="Point_of_Sales.MVVM.Views.LoginPage"
             BackgroundColor="{StaticResource Background}"
             Shell.NavBarIsVisible="False">

    <Grid>
        
        <!-- HEADER SECTION (Logo, Title, Subtitle) -->

        <ScrollView VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Padding="32,56,32,40"
                                 Spacing="0" VerticalOptions="Center">

                <VerticalStackLayout Spacing="4" Margin="0,0,0,36"
                                     HorizontalOptions="Center">
                    
                    <Label FontSize="34" FontAttributes="Bold"
                           TextColor="{StaticResource TextMain}" HorizontalOptions="Center">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="Sign " />
                                <Span Text="In" TextColor="{StaticResource Primary}" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                    
                </VerticalStackLayout>

                <Border BackgroundColor="{StaticResource CardDark}"
                        StrokeShape="RoundRectangle 8"
                        Stroke="{StaticResource BorderGray}" StrokeThickness="1"
                        Padding="24,28" Margin="0,0,0,20">

                    <VerticalStackLayout Spacing="25">
                        
                        <!--USERNAME-->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="EMAIL OR USERNAME" FontSize="11"
                                   CharacterSpacing="1" TextColor="{StaticResource TextSub}" 
                                   FontAttributes="Bold"/>
                            <Border BackgroundColor="{StaticResource CardLight}"
                                    StrokeShape="RoundRectangle 4"
                                    Stroke="Transparent" 
                                    Padding="16,0">
                                <Entry x:Name="UsernameEntry"
                                       Text="{Binding Username}"
                                       Placeholder="Email or username"
                                       PlaceholderColor="{StaticResource TextSub}"
                                       TextColor="White"
                                       HeightRequest="56" FontSize="15" />
                            </Border>
                        </VerticalStackLayout>
                        
                        <!--PASSWORD-->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="PASSWORD" FontSize="11"
                                   CharacterSpacing="1" TextColor="{StaticResource TextSub}"
                                   FontAttributes="Bold"/>
                            <Border BackgroundColor="{StaticResource CardLight}"
                                    StrokeShape="RoundRectangle 4"
                                    Stroke="Transparent"
                                    Padding="16,0">
                                <Entry x:Name="PasswordEntry"
                                       Text="{Binding Password}"
                                       Placeholder="Password"
                                       PlaceholderColor="{StaticResource TextSub}"
                                       IsPassword="{Binding IsPasswordHidden}"
                                       TextColor="White"
                                       HeightRequest="56" FontSize="15" />
                            </Border>

                            <HorizontalStackLayout Spacing="8" Margin="0,5,0,0">
                                <CheckBox Color="{StaticResource Primary}"
                                          CheckedChanged="OnShowPasswordCheckedChanged" />
                                <Label Text="Show Password"
                                       FontSize="13" TextColor="{StaticResource TextSub}"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

                <!--SIGN IN-->
                <Button Text="Sign In"
                        Command="{Binding LoginCommand}"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White"
                        FontAttributes="Bold"
                        FontSize="16"
                        CornerRadius="4"
                        HeightRequest="56"
                        Margin="0,10,0,12" />
                
                <!--FORGOT PASSWORD-->
                <Button Text="Forgot password?"
                        FontSize="13"
                        TextColor="{StaticResource TextSub}"
                        HorizontalOptions="Center"
                        BackgroundColor="Transparent"
                        Command="{Binding GoToForgotCommand}" />

                <HorizontalStackLayout HorizontalOptions="Center"
                                       Spacing="6" Margin="0,30,0,0">
                    <Label Text="New to the system?"
                           FontSize="15" TextColor="{StaticResource TextSub}"
                           VerticalOptions="Center" />
                    <Button Text="Sign up now."
                            Command="{Binding GoToRegisterCommand}"
                            FontSize="15"
                            FontAttributes="Bold"
                            TextColor="White"
                            Padding="0"
                            BackgroundColor="Transparent" />
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>