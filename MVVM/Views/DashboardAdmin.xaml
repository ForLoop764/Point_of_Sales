<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Point_of_Sales.MVVM.Views.DashboardAdmin"
             BackgroundColor="#141414"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="25">

            <Grid ColumnDefinitions="Auto, *, Auto" Padding="20,10">
                

                <Label Grid.Column="1" 
                       Text="DASHBOARD" 
                       TextColor="White" 
                       FontAttributes="Bold" 
                       VerticalOptions="Center" 
                        HorizontalOptions="Start"/>
            </Grid>

            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="15" RowSpacing="15">

                <Frame Grid.ColumnSpan="2" CornerRadius="4" Padding="20" HasShadow="False" BorderColor="Transparent">
                    <Frame.Background>
                        <LinearGradientBrush EndPoint="1,0">
                            <GradientStop Color="#E50914" Offset="0.1"/>
                            <GradientStop Color="#B20710" Offset="1"/>
                        </LinearGradientBrush>
                    </Frame.Background>
                    <VerticalStackLayout>
                        <Label Text="TOTAL SALES TODAY" FontSize="11" FontAttributes="Bold" TextColor="#FFC1C1" CharacterSpacing="1"/>
                        <Label Text="{Binding Sales}" FontSize="34" FontAttributes="Bold" TextColor="White"/>
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Row="1" BackgroundColor="#262626" CornerRadius="4" Padding="15" HasShadow="False" BorderColor="Transparent">
                    <VerticalStackLayout>
                        <Label Text="Transactions" TextColor="#808080" FontSize="12"/>
                        <Label Text="{Binding Transactions}" FontSize="20" FontAttributes="Bold" TextColor="White"/>
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Row="1" Grid.Column="1" BackgroundColor="#262626" CornerRadius="4" Padding="15" HasShadow="False" BorderColor="Transparent">
                    <VerticalStackLayout>
                        <Label Text="Active Now" TextColor="#808080" FontSize="12"/>
                        <Label Text="{Binding ActiveUsers}" FontSize="20" FontAttributes="Bold" TextColor="White"/>
                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <VerticalStackLayout Spacing="10">
                <Label Text="User Activity" TextColor="White" FontSize="18" FontAttributes="Bold" Margin="0,10,0,5"/>

                <CollectionView ItemsSource="{Binding Users}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame BackgroundColor="#1F1F1F" CornerRadius="2" Margin="0,2" Padding="12" HasShadow="False" BorderColor="#333333">
                                <Grid ColumnDefinitions="Auto, *, Auto">
                                    <BoxView WidthRequest="4" BackgroundColor="{Binding Color}" VerticalOptions="Fill" Margin="-12,-12,12,-12"/>

                                    <VerticalStackLayout Grid.Column="1">
                                        <Label Text="{Binding Name}" FontAttributes="Bold" TextColor="White" FontSize="14"/>
                                        <Label Text="{Binding Role}" FontSize="11" TextColor="#808080"/>
                                    </VerticalStackLayout>

                                    <Label Grid.Column="2" 
                                           Text="{Binding Status}" 
                                           TextColor="{Binding Color}" 
                                           FontSize="11" 
                                           VerticalOptions="Center" 
                                           FontAttributes="Bold"/>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <Frame BackgroundColor="#1F1F1F" CornerRadius="4" Padding="15" HasShadow="False" BorderColor="#333333">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Recent History" TextColor="White" FontAttributes="Bold" FontSize="16"/>

                    <BoxView HeightRequest="1" Color="#333333" HorizontalOptions="Fill"/>

                    <CollectionView ItemsSource="{Binding RecentTransactions}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,*,*" Padding="0,8">
                                    <Label Text="{Binding Id}" TextColor="#B3B3B3" FontSize="13"/>
                                    <Label Text="{Binding Amount}" Grid.Column="1" TextColor="White" FontAttributes="Bold" FontSize="13"/>
                                    <Label Text="{Binding Type}" Grid.Column="2" TextColor="{Binding Color}" HorizontalOptions="End" FontSize="12" FontAttributes="Bold"/>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>